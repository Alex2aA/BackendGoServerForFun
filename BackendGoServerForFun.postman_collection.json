{
	"info": {
		"name": "BackendGoServerForFun",
		"description": "Тестовые запросы для проверки микросервисов:\n- user-service (порт 8081): регистрация/логин\n- booking-service (порт 8082): hostel/house/booking\n\nЗапуск: docker-compose up --build -d",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "user-service (8081)",
			"description": "Сервис аутентификации пользователей",
			"item": [
				{
					"name": "Register user",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 201 Created\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test(\"Has token\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"});",
									"pm.variables.set(\"authToken\", pm.response.json().token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"john\",\n    \"password\": \"secret123\"\n}"
						},
						"url": {
							"raw": "http://localhost:8081/api/user/register",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8081",
							"path": [
								"api",
								"user",
								"register"
							]
						},
						"description": "Регистрация нового пользователя. Возвращает JWT токен."
					},
					"response": [
						{
							"name": "Success",
							"status": "Created",
							"code": 201,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n    \"token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"message\": \"User registered successfully\"\n}"
						}
					]
				},
				{
					"name": "Login user",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Has token\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"});",
									"pm.variables.set(\"authToken\", pm.response.json().token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"john\",\n    \"password\": \"secret123\"\n}"
						},
						"url": {
							"raw": "http://localhost:8081/api/user/login",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8081",
							"path": [
								"api",
								"user",
								"login"
							]
						},
						"description": "Логин существующего пользователя. Возвращает JWT токен."
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n    \"token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"message\": \"Login successful\"\n}"
						}
					]
				}
			]
		},
